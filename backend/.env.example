# Server Port
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB Atlas or Local Connection String)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/crm?retryWrites=true&w=majority

# JWT Token Settings
JWT_SECRET=your_jwt_secret_key_change_me_to_something_secure_and_long
JWT_EXPIRES_IN=30d

# Google OAuth 2.0 Credentials (for login)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Cloudinary Integration (For uploading files & images)
# If left empty, the application will automatically fall back to local disk storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
